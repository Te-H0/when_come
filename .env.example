# when_come 환경변수 템플릿
# 실제 값은 각 프로젝트의 .env.local에 작성 (gitignore됨)
# 자세한 설명: docs/env-guide.md

# ── FRONTEND (when_come_fe/.env.local) ──────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_NAVER_MAP_CLIENT_ID=

# ── BACKEND (when_come_be/.env.local) ───────────────────────
ODSAY_API_KEY=
SEOUL_BUS_API_KEY=
SEOUL_SUBWAY_API_KEY=
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# Supabase 로컬 (supabase start 실행 후 출력값)
SUPABASE_URL_LOCAL=http://127.0.0.1:54321
SUPABASE_ANON_KEY_LOCAL=
SUPABASE_SERVICE_ROLE_KEY_LOCAL=

# Supabase 원격
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # ⚠️ Edge Function 내부 전용, FE 절대 노출 금지
